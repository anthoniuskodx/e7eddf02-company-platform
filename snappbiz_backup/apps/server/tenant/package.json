{
  "name": "tenant",
  "scripts": {
    "dev": "bun run --hot src/index.ts --hostname 0.0.0.0",
    "dev:wrangler": "wrangler dev --env=dev --port 3001",
    "build": "bun build --minify src/index.ts --outfile build/worker.ts",
    "deploy": "wrangler deploy --env=prod"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "wrangler": "^3.85.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}