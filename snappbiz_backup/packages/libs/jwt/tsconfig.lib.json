{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "module": "commonjs",
    "types": ["node"]
  },
  "exclude": [
    "**/*.spec.ts",
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "include": [
    "src/*.ts",
    "src/*.d.ts",
  ]
}
