{
  "name": "@snappbiz/auth-worker",
  "version": "0.0.1",
  "scripts": {
    "dev": "bun run --hot src/index.ts --hostname 0.0.0.0",
    "dev:wrangler": "wrangler dev --persist-to='../../../packages/libs/drizzle/databases/auth' --env=dev --port 3001",
    "build": "bun build --minify src/index.ts --outfile build/worker.ts",
    "deploy": "wrangler deploy --env=prod"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@types/bun": "latest",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.0",
    "nx": "20.0.11",
    "wrangler": "^3.85.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@oslojs/encoding": "^1.1.0",
    "@snappbiz/drizzle-db": "0.0.1",
    "cloudflare": "^3.5.0",
    "drizzle-orm": "^0.36.1",
    "drizzle-zod": "^0.5.1",
    "libphonenumber-js": "^1.11.13",
    "zod": "^3.23.8"
  },
  "nx": {
    "name": "@snappbiz/auth-worker"
  }
}
